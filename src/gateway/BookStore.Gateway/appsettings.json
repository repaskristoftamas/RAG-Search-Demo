{
  "Services": {
    "KeywordSearchBaseUrl": "http://localhost:5020",
    "SemanticSearchBaseUrl": "http://localhost:5030"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/books/{**catch-all}"
        }
      },
      "keyword-search-route": {
        "ClusterId": "keyword-search-cluster",
        "Match": {
          "Path": "/api/v1/keyword-search/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/{**catch-all}"
          }
        ]
      },
      "semantic-search-route": {
        "ClusterId": "semantic-search-cluster",
        "Match": {
          "Path": "/api/v1/semantic-search/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:5010"
          }
        }
      },
      "keyword-search-cluster": {
        "Destinations": {
          "keyword-search": {
            "Address": "http://localhost:5020"
          }
        }
      },
      "semantic-search-cluster": {
        "Destinations": {
          "semantic-search": {
            "Address": "http://localhost:5030"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
